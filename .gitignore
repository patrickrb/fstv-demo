# Rendered IQ (large, reproducible from scripts)
*.iq16
*.iq8

# Everything under media/ is reproducible (scripts\fetch-media.cmd and
# scripts/fetch-clip.sh). Keep the directory but don't commit its contents.
media/*
!media/.gitkeep

# Firmware archives + staged .frm files (reproducible; large)
firmware/

# Temp
*.tmp

# Claude Code per-user settings (not for sharing)
.claude/settings.local.json
